# Neon Postgres connection string (Vercel -> Storage -> Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Session aláíró titok (min. 32 karakter). Generálás: openssl rand -base64 32
SESSION_SECRET="cseréld-le-egy-hosszú-véletlen-titokra-min-32-karakter"

# Vercel Blob olvasás/írás token (Vercel -> Storage -> Blob -> Tokens)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Az első regisztrációhoz használható bootstrap meghívókód (opcionális).
# Ha be van állítva, ezzel a kóddal lehet létrehozni az első (admin) fiókot.
BOOTSTRAP_INVITE_CODE="valami-titkos-alapito-kod"
